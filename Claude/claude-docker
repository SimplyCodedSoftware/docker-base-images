#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="simplycodedsoftware/claude-sandbox:latest"
PROJECT_DIR=""
WORKTREE=""
WORKTREE_DIR=""
RESTORE=false
ENTRYPOINT_PROMPT=""
CLAUDE_CONFIG="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
CLAUDE_ARGS=()

usage() {
    cat <<EOF
Usage: claude-docker [options] [project-dir] [-- extra claude args...]

Options:
  --worktree, -w <name>       Create a git worktree on the given branch
  --worktree-dir, -d <path>   Host directory for worktrees (required with --worktree)
  --restore                   Restore a previously detached worktree
  --entrypoint-prompt <text>  Run a Claude prompt to set up the environment before starting
  --help                      Show this help

Environment:
  CLAUDE_CONFIG_DIR      Claude config directory (default: \$HOME/.claude)

Examples:
  claude-docker
  claude-docker ~/projects/my-app
  claude-docker --worktree feature-foo --worktree-dir /tmp/claude-worktrees ~/projects/my-app
  claude-docker -w fix-bug -d /tmp/claude-worktrees .
  claude-docker -w fix-bug -d /tmp/claude-worktrees --restore .
  CLAUDE_CONFIG_DIR=~/.claude-personal claude-docker .
  claude-docker --entrypoint-prompt="Add .env file in the root of the project" .
  claude-docker . -- --continue
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help)       usage ;;
        --restore)    RESTORE=true; shift ;;
        --worktree=*)     WORKTREE="${1#*=}"; shift ;;
        --worktree|-w)    WORKTREE="$2"; shift; shift ;;
        --worktree-dir=*) WORKTREE_DIR="${1#*=}"; shift ;;
        --worktree-dir|-d) WORKTREE_DIR="$2"; shift; shift ;;
        --entrypoint-prompt=*) ENTRYPOINT_PROMPT="${1#*=}"; shift ;;
        --entrypoint-prompt)   ENTRYPOINT_PROMPT="$2"; shift; shift ;;
        --)           shift; CLAUDE_ARGS=("$@"); break ;;
        *)            PROJECT_DIR="$1"; shift ;;
    esac
done

PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"
CLAUDE_CONFIG="$(cd "$CLAUDE_CONFIG" && pwd)"

if [ -n "$WORKTREE" ]; then
    GIT_ROOT="$(git -C "$PROJECT_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
    if [ -z "$GIT_ROOT" ]; then
        echo "Error: $PROJECT_DIR is not inside a git repository" >&2
        exit 1
    fi
    if [ "$PROJECT_DIR" != "$GIT_ROOT" ]; then
        echo "Error: please run from the git root: $GIT_ROOT" >&2
        exit 1
    fi
fi

if [ -n "$WORKTREE" ] && [ -z "$WORKTREE_DIR" ]; then
    echo "Error: --worktree-dir is required when using --worktree" >&2
    echo "  Example: claude-docker -w $WORKTREE -d /tmp/claude-worktrees $PROJECT_DIR" >&2
    exit 1
fi

if [ -n "$WORKTREE_DIR" ]; then
    WORKTREE_DIR="$(mkdir -p "$WORKTREE_DIR" && cd "$WORKTREE_DIR" && pwd)"
fi

docker pull "$IMAGE_NAME"

echo "Starting Claude Code in Docker..."
echo "  Project:  $PROJECT_DIR"
echo "  Config:   $CLAUDE_CONFIG"
[ -n "$WORKTREE" ] && echo "  Worktree: $WORKTREE"
[ -n "$WORKTREE_DIR" ] && echo "  Worktree dir: $WORKTREE_DIR"
[ -n "$ENTRYPOINT_PROMPT" ] && echo "  Entrypoint:  $ENTRYPOINT_PROMPT"

OPTIONAL_MOUNTS=()
EXTRA_ENV=()
[ -f "$HOME/.claude.json" ]   && OPTIONAL_MOUNTS+=(-v "$HOME/.claude.json:/home/claude/.claude.host.json:ro")
[ -d "$HOME/.ssh" ]           && OPTIONAL_MOUNTS+=(-v "$HOME/.ssh:/home/claude/.ssh:ro")
[ -f "$HOME/.gitconfig" ]     && OPTIONAL_MOUNTS+=(-v "$HOME/.gitconfig:/home/claude/.gitconfig:ro")
[ -d "$HOME/.config/gh" ]     && OPTIONAL_MOUNTS+=(-v "$HOME/.config/gh:/home/claude/.config/gh:ro")

GH_TOKEN="$(gh auth token 2>/dev/null || true)"
[ -n "$GH_TOKEN" ] && EXTRA_ENV+=(-e "GH_TOKEN=$GH_TOKEN")
[ -n "$ENTRYPOINT_PROMPT" ] && EXTRA_ENV+=(-e "ENTRYPOINT_PROMPT=$ENTRYPOINT_PROMPT")
EXTRA_ENV+=(-e "HOST_PROJECT_DIR=$PROJECT_DIR")
EXTRA_ENV+=(-e "HOST_HOME=$HOME")

DEFAULT_CONFIG="$(cd "$HOME/.claude" && pwd)"
if [[ "$CLAUDE_CONFIG" != "$DEFAULT_CONFIG" ]]; then
    EXTRA_ENV+=(-e "CLAUDE_STRIP_AUTH=1")
fi

if [ -n "$WORKTREE" ]; then
    REPO_NAME="$(basename "$PROJECT_DIR")"
    SAFE_BRANCH="$(echo "$WORKTREE" | tr '/' '-')"
    ACTUAL_WORKTREE="$WORKTREE_DIR/$REPO_NAME/$SAFE_BRANCH"
    if [ -d "$ACTUAL_WORKTREE" ]; then
        if [ "$RESTORE" = false ]; then
            echo "Error: worktree already exists at $ACTUAL_WORKTREE" >&2
            echo "  Use --restore to resume it, or remove it manually:" >&2
            echo "    rm -rf $ACTUAL_WORKTREE" >&2
            exit 1
        fi
        echo "Restoring worktree at $ACTUAL_WORKTREE"
    else
        if [ "$RESTORE" = true ]; then
            echo "Error: no worktree to restore at $ACTUAL_WORKTREE" >&2
            exit 1
        fi
        echo "Creating worktree for branch: $WORKTREE"
        mkdir -p "$WORKTREE_DIR/$REPO_NAME"
        git -C "$PROJECT_DIR" worktree add "$ACTUAL_WORKTREE" "$WORKTREE" 2>/dev/null \
            || git -C "$PROJECT_DIR" worktree add --force "$ACTUAL_WORKTREE" "$WORKTREE" 2>/dev/null \
            || git -C "$PROJECT_DIR" worktree add -b "$WORKTREE" "$ACTUAL_WORKTREE"
    fi
    # Mount worktree + main repo's .git so git operations work inside the container
    PROJECT_MOUNT=(-v "$ACTUAL_WORKTREE:$ACTUAL_WORKTREE" -v "$PROJECT_DIR/.git:$PROJECT_DIR/.git")
    EXTRA_ENV+=(-e "HOST_PROJECT_DIR=$ACTUAL_WORKTREE")
else
    PROJECT_MOUNT=(-v "$PROJECT_DIR:$PROJECT_DIR")
fi

exec docker run -it --rm \
    --hostname claude-sandbox \
    --network host \
    --pull always \
    "${PROJECT_MOUNT[@]}" \
    -v "$CLAUDE_CONFIG:/home/claude/.claude" \
    -v /var/run/docker.sock:/var/run/docker.sock \
    "${OPTIONAL_MOUNTS[@]}" \
    "${EXTRA_ENV[@]+"${EXTRA_ENV[@]}"}" \
    "$IMAGE_NAME" "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"

